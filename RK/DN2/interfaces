PC1:
auto eth0
iface eth0 inet static
	address 10.6.0.100
	netmask 255.255.0.0
	gateway 10.6.0.1

PC2:
auto eth0
iface eth0 inet static
	address 192.168.0.100
	netmask 255.255.255.0
	gateway 192.168.0.1

PC3:
auto eth0
iface eth0 inet static
	address 172.16.0.100
	netmask 255.255.255.0
	gateway 172.16.0.1

R1:
configure
set interfaces ethernet eth0 address 10.6.0.1/16
set interfaces ethernet eth1 address 1.1.1.1/30
set interfaces ethernet eth2 address 1.1.1.10/30
set protocols bgp 65531 neighbor 1.1.1.2 remote-as '65532'
set protocols bgp 65531 neighbor 1.1.1.9 remote-as '65533'
set protocols bgp 65531 neighbor 1.1.1.2 update-source 1.1.1.1
set protocols bgp 65531 neighbor 1.1.1.9 update-source 1.1.1.10
set protocols bgp 65531 parameters router-id 1.1.1.1
set protocols bgp 65531 parameters router-id 1.1.1.10
set protocols bgp 65531 network 10.6.0.0/16
commit
save
exit

R2:
configure
set interfaces ethernet eth0 address 192.168.0.1/24
set interfaces ethernet eth1 address 1.1.1.5/30
set interfaces ethernet eth2 address 1.1.1.2/30
set protocols bgp 65532 neighbor 1.1.1.6 remote-as '65533'
set protocols bgp 65532 neighbor 1.1.1.1 remote-as '65531'
set protocols bgp 65532 neighbor 1.1.1.6 update-source 1.1.1.5
set protocols bgp 65532 neighbor 1.1.1.1 update-source 1.1.1.2
set protocols bgp 65532 parameters router-id 1.1.1.5
set protocols bgp 65532 parameters router-id 1.1.1.2
set protocols bgp 65532 network 192.168.0.0/24
commit
save
exit

R3:
configure
set interfaces ethernet eth0 address 172.16.0.1/24
set interfaces ethernet eth1 address 1.1.1.9/30
set interfaces ethernet eth2 address 1.1.1.6/30
set protocols bgp 65533 neighbor 1.1.1.10 remote-as '65531'
set protocols bgp 65533 neighbor 1.1.1.5 remote-as '65532'
set protocols bgp 65533 neighbor 1.1.1.10 update-source 1.1.1.9
set protocols bgp 65533 neighbor 1.1.1.5 update-source 1.1.1.6
set protocols bgp 65533 parameters router-id 1.1.1.9
set protocols bgp 65533 parameters router-id 1.1.1.6
set protocols bgp 65533 network 172.16.0.0/24
commit
save
exit
